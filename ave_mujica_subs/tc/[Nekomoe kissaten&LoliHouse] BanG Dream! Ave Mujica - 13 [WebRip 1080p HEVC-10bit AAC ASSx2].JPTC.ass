Dialogue: 0,0:00:04.05,0:00:05.78,Dial_JP,,0,0,0,,豊川さん　時間です
Dialogue: 0,0:00:10.18,0:00:11.38,Dial_JP,,0,0,0,,まいりましょう
Dialogue: 0,0:00:12.58,0:00:14.49,Dial_JP,,0,0,0,,やろうよ　円陣
Dialogue: 0,0:00:14.49,0:00:16.10,Dial_JP,,0,0,0,,もう出番なんだけど
Dialogue: 0,0:00:16.10,0:00:17.83,Dial_JP,,0,0,0,,やるなら早くして
Dialogue: 0,0:00:17.83,0:00:19.75,Dial_JP,,0,0,0,,ほら　りっきーも
Dialogue: 0,0:00:19.75,0:00:21.21,Dial_JP,,0,0,0,,頑張るぞ
Dialogue: 0,0:00:21.21,0:00:22.16,Dial_JP,,0,0,0,,マイ…
Dialogue: 0,0:00:22.16,0:00:23.47,Dial_JP,,0,0,0,,やるなら燈でしょう
Dialogue: 0,0:00:24.51,0:00:25.66,Dial_JP,,0,0,0,,じゃ　ともりん
Dialogue: 0,0:00:26.23,0:00:28.26,Dial_JP,,0,0,0,,「マイ～ゴ～」ね
Dialogue: 0,0:00:30.11,0:00:31.02,Dial_JP,,0,0,0,,えっと…
Dialogue: 0,0:00:31.34,0:00:33.01,Dial_JP,,0,0,0,,マイ　ゴー
Dialogue: 0,0:00:32.24,0:00:33.30,Dial_JP,,0,1000,0,,待って待って
Dialogue: 0,0:00:33.30,0:00:34.15,Dial_JP,,0,0,0,,{\fad(0,360)}ゴー
Dialogue: 0,0:00:34.46,0:00:36.95,Dial_JP,,0,0,0,,この日　この夜は一度きり
Dialogue: 0,0:00:37.54,0:00:38.59,Dial_JP,,0,0,0,,カルペ・ディエム
Dialogue: 0,0:00:38.99,0:00:40.60,Dial_JP,,0,0,0,,今日という花を摘み
Dialogue: 0,0:00:40.82,0:00:43.54,Dial_JP,,0,0,0,,今宵ひと時の享楽に溺れましょう
Dialogue: 0,0:00:43.54,0:00:44.65,Dial_JP,,0,0,0,,享楽ですか
Dialogue: 0,0:00:44.65,0:00:46.48,Dial_JP,,0,0,0,,悪いことするみたいだね
Dialogue: 0,0:00:49.11,0:00:51.38,Dial_JP,,0,0,0,,では　楽しみましょう
Dialogue: 0,0:00:53.83,0:00:55.54,Dial_JP,,0,0,0,,もっかい　もっかい
Dialogue: 0,0:00:55.54,0:00:57.29,Dial_JP,,0,0,0,,「ゴー」そろってなかった
Dialogue: 0,0:00:57.29,0:00:58.50,Dial_JP,,0,0,0,,また今度ね
Dialogue: 0,0:00:58.50,0:01:00.42,Dial_JP,,0,0,0,,今度っていつ
Dialogue: 0,0:01:01.34,0:01:02.55,Dial_JP,,0,0,0,,今食べない
Dialogue: 0,0:01:05.46,0:01:07.71,Dial_JP,,0,0,0,,燈　気持ち作ってる
Dialogue: 0,0:01:11.60,0:01:13.42,Dial_JP,,0,0,0,,行くよ　りっきー
Dialogue: 0,0:05:19.98,0:05:22.65,Dial_JP,,0,0,0,,朝　金木犀の匂い
Dialogue: 0,0:05:23.25,0:05:25.93,Dial_JP,,0,0,0,,あのちゃんが咲いてる場所見つけてくれて
Dialogue: 0,0:05:26.66,0:05:28.47,Dial_JP,,0,0,0,,木漏れ日が優しかった
Dialogue: 0,0:05:31.60,0:05:34.54,Dial_JP,,0,0,0,,スタジオでノートを準備してるとき
Dialogue: 0,0:05:34.93,0:05:36.82,Dial_JP,,0,0,0,,背中に立希ちゃんの音
Dialogue: 0,0:05:38.00,0:05:42.41,Dial_JP,,0,0,0,,練習前のトントンって　落ち着く音
Dialogue: 0,0:05:43.12,0:05:46.07,Dial_JP,,0,0,0,,楽奈ちゃんと一緒に金平糖食べた
Dialogue: 0,0:05:46.64,0:05:49.74,Dial_JP,,0,0,0,,楽奈ちゃんは緑色のバリバリかんで
Dialogue: 0,0:05:50.16,0:05:51.81,Dial_JP,,0,0,0,,「抹茶味じゃない」って
Dialogue: 0,0:05:51.81,0:05:53.36,Dial_JP,,0,0,0,,メロン味だった
Dialogue: 0,0:05:54.30,0:05:56.64,Dial_JP,,0,0,0,,さっき　よろけたとき
Dialogue: 0,0:05:56.98,0:05:59.59,Dial_JP,,0,0,0,,そよちゃんが手を引いてくれた
Dialogue: 0,0:05:59.95,0:06:03.97,Dial_JP,,0,0,0,,そよちゃんの手　この前より少し冷たくて
Dialogue: 0,0:06:05.13,0:06:07.06,Dial_JP,,0,0,0,,季節が変わってた
Dialogue: 0,0:06:10.21,0:06:11.07,Dial_JP,,0,0,0,,ともりん
Dialogue: 0,0:16:05.22,0:16:07.39,Dial_JP,,0,0,0,,ここがパラディースス？
Dialogue: 0,0:16:08.29,0:16:09.20,Dial_JP,,0,0,0,,新入りかい
Dialogue: 0,0:16:09.59,0:16:12.49,Dial_JP,,0,0,0,,僕は　悲しみの騎士　ドロリス
Dialogue: 0,0:16:12.49,0:16:15.77,Dial_JP,,0,0,0,,女神　オブリビオニスに仕えるために来た
Dialogue: 0,0:16:17.02,0:16:20.04,Dial_JP,,0,0,0,,そんな物好き　俺たち以外にもいたんだ
Dialogue: 0,0:16:20.04,0:16:22.25,Dial_JP,,0,0,0,,我々も同じだ　ドロリス
Dialogue: 0,0:16:22.57,0:16:24.94,Dial_JP,,0,0,0,,私は恐れの騎士　ティモリス
Dialogue: 0,0:16:24.94,0:16:26.83,Dial_JP,,0,0,0,,愛の騎士　アモーリス
Dialogue: 0,0:16:27.03,0:16:28.38,Dial_JP,,0,0,0,,そんであっちは…
Dialogue: 0,0:16:28.89,0:16:29.94,Dial_JP,,0,0,0,,何してんの
Dialogue: 0,0:16:30.45,0:16:31.36,Dial_JP,,0,0,0,,聞いてる
Dialogue: 0,0:16:31.36,0:16:32.71,Dial_JP,,0,0,0,,だから　何を
Dialogue: 0,0:16:34.19,0:16:36.05,Dial_JP,,0,0,0,,世界が壊れる音
Dialogue: 0,0:16:36.27,0:16:39.01,Dial_JP,,0,0,0,,死の騎士　モーティス　変なヤツ
Dialogue: 0,0:16:40.06,0:16:41.51,Dial_JP,,0,0,0,,心配しなくていい
Dialogue: 0,0:16:41.77,0:16:43.65,Dial_JP,,0,0,0,,ここにいれば　恐ろしいことはない
Dialogue: 0,0:16:43.65,0:16:45.30,Dial_JP,,0,0,0,,この私が約束しよう
Dialogue: 0,0:16:46.75,0:16:48.66,Dial_JP,,0,0,0,,適当なことばっか
Dialogue: 0,0:16:48.66,0:16:50.01,Dial_JP,,0,0,0,,誰が適当だって
Dialogue: 0,0:16:50.57,0:16:52.87,Dial_JP,,0,0,0,,所詮うたかたの箱庭だろう
Dialogue: 0,0:16:54.30,0:16:56.74,Dial_JP,,0,0,0,,世界が壊れるそのときまで
Dialogue: 0,0:16:56.74,0:17:00.17,Dial_JP,,0,0,0,,楽しく踊って　暮らすだけの
Dialogue: 0,0:17:03.25,0:17:05.60,Dial_JP,,0,0,0,,欺瞞に満ちたパラディースス
Dialogue: 0,0:17:10.24,0:17:13.35,Dial_JP,,0,0,0,,オブリビオニスはいない　残念だけど
Dialogue: 0,0:17:14.18,0:17:16.56,Dial_JP,,0,0,0,,ずっと前に消えてしまったって
Dialogue: 0,0:17:16.56,0:17:17.75,Dial_JP,,0,0,0,,そんな
Dialogue: 0,0:17:18.23,0:17:20.26,Dial_JP,,0,0,0,,僕たちもずっと願ってる
Dialogue: 0,0:17:21.09,0:17:23.36,Dial_JP,,0,0,0,,いつか彼女が楽園に戻り
Dialogue: 0,0:17:23.99,0:17:26.30,Dial_JP,,0,0,0,,忘却を与えてくれるその日を
Dialogue: 0,0:17:28.00,0:17:31.69,Dial_JP,,0,0,0,,僕の命は　たくさんの死の上に立ってる
Dialogue: 0,0:17:32.46,0:17:36.30,Dial_JP,,0,0,0,,望みもしないのに　ただ僕が生きるため
Dialogue: 0,0:17:37.07,0:17:40.38,Dial_JP,,0,0,0,,昨日も１つ　今日も１つ
Dialogue: 0,0:17:41.59,0:17:45.09,Dial_JP,,0,0,0,,全部　忘れてしまいたい
Dialogue: 0,0:17:46.47,0:17:48.30,Dial_JP,,0,0,0,,世界が壊れる音？
Dialogue: 0,0:17:48.73,0:17:50.42,Dial_JP,,0,0,0,,俺には聞こえない
Dialogue: 0,0:17:50.86,0:17:53.43,Dial_JP,,0,0,0,,なんで　なんであいつには
Dialogue: 0,0:17:53.67,0:17:58.51,Dial_JP,,0,0,0,,羨み　憎んでしまうほどの愛なんて　忘れさせてくれよ
Dialogue: 0,0:17:59.50,0:18:01.27,Dial_JP,,0,0,0,,誰も私を信じない
Dialogue: 0,0:18:01.27,0:18:02.74,Dial_JP,,0,0,0,,信じてくれない
Dialogue: 0,0:18:03.21,0:18:06.14,Dial_JP,,0,0,0,,こんな恐ろしさ　忘れたいのに
Dialogue: 0,0:18:07.55,0:18:10.27,Dial_JP,,0,0,0,,ただ　願うことしかできない
Dialogue: 0,0:18:10.27,0:18:11.44,Dial_JP,,0,0,0,,イヤだ
Dialogue: 0,0:18:11.44,0:18:13.49,Dial_JP,,0,0,0,,僕はもう耐えられない
Dialogue: 0,0:18:13.79,0:18:15.62,Dial_JP,,0,0,0,,罪深い我が身
Dialogue: 0,0:18:15.94,0:18:18.37,Dial_JP,,0,0,0,,存在そのものが罪なんだ
Dialogue: 0,0:18:18.37,0:18:21.37,Dial_JP,,0,0,0,,全て忘れて　救われたい
Dialogue: 0,0:18:21.37,0:18:22.62,Dial_JP,,0,0,0,,愛じゃダメ
Dialogue: 0,0:18:22.82,0:18:23.75,Dial_JP,,0,0,0,,ダメだ
Dialogue: 0,0:18:23.75,0:18:24.82,Dial_JP,,0,0,0,,恐れでは
Dialogue: 0,0:18:25.00,0:18:26.13,Dial_JP,,0,0,0,,違う
Dialogue: 0,0:18:26.33,0:18:27.31,Dial_JP,,0,0,0,,死をあげる
Dialogue: 0,0:18:27.63,0:18:28.71,Dial_JP,,0,0,0,,要らない
Dialogue: 0,0:18:29.13,0:18:32.91,Dial_JP,,0,0,0,,愛でも　恐れでも　死でも　悲しみでもなく
Dialogue: 0,0:18:33.97,0:18:38.31,Dial_JP,,0,0,0,,忘却だけが　僕をこの苦しみから救ってくれる
Dialogue: 0,0:18:40.26,0:18:41.52,Dial_JP,,0,0,0,,本当に？
Dialogue: 0,0:18:42.82,0:18:43.82,Dial_JP,,0,0,0,,この声…
Dialogue: 0,0:18:44.31,0:18:47.06,Dial_JP,,0,0,0,,忘却だけが　この地に来た理由？
Dialogue: 0,0:18:47.06,0:18:51.35,Dial_JP,,0,0,0,,まただ　いつも聞こえてくるこの声
Dialogue: 0,0:18:51.35,0:18:52.51,Dial_JP,,0,0,0,,ドロリス
Dialogue: 0,0:18:53.54,0:18:55.95,Dial_JP,,0,0,0,,お前の本当の願いは？
Dialogue: 0,0:19:02.57,0:19:03.34,Dial_JP,,0,0,0,,まさか…
Dialogue: 0,0:19:03.59,0:19:04.89,Dial_JP,,0,0,0,,オブリビオニス？
Dialogue: 0,0:19:07.98,0:19:09.21,Dial_JP,,0,0,0,,忘却の女神よ
Dialogue: 0,0:19:09.71,0:19:12.02,Dial_JP,,0,0,0,,どうか　私をあなたの騎士に
Dialogue: 0,0:19:26.24,0:19:27.09,Dial_JP,,0,0,0,,待って
Dialogue: 0,0:19:27.44,0:19:29.14,Dial_JP,,0,0,0,,僕もあなたの騎士に
Dialogue: 0,0:19:29.14,0:19:30.49,Dial_JP,,0,0,0,,忘却の福音を
Dialogue: 0,0:19:30.49,0:19:32.11,Dial_JP,,0,0,0,,幾度繰り返すのです
Dialogue: 0,0:19:33.37,0:19:37.74,Dial_JP,,0,0,0,,幾度忘却を与えても　あなたは楽園に戻ってくる
Dialogue: 0,0:19:38.01,0:19:39.27,Dial_JP,,0,0,0,,何を言って
Dialogue: 0,0:19:39.81,0:19:42.25,Dial_JP,,0,0,0,,ここに来たのは今日が初めてで
Dialogue: 0,0:19:42.25,0:19:43.37,Dial_JP,,0,0,0,,本当に？
Dialogue: 0,0:19:45.46,0:19:47.76,Dial_JP,,0,0,0,,思い出せ　ドロリス
Dialogue: 0,0:19:48.22,0:19:50.46,Dial_JP,,0,0,0,,何度この地を訪れた？
Dialogue: 0,0:19:51.81,0:19:54.85,Dial_JP,,0,0,0,,なぜ　オブリビオニスの名を知っている？
Dialogue: 0,0:19:56.10,0:19:58.97,Dial_JP,,0,0,0,,なぜ　お前は忘却を求める？
Dialogue: 0,0:20:00.15,0:20:02.11,Dial_JP,,0,0,0,,ただ会いたくて…
Dialogue: 0,0:20:02.62,0:20:04.69,Dial_JP,,0,0,0,,あなたはわたくしの騎士ではない
Dialogue: 0,0:20:11.06,0:20:12.62,Dial_JP,,0,0,0,,あなたを忘れる
Dialogue: 0,0:20:12.86,0:20:16.39,Dial_JP,,0,0,0,,それでそばにいられるなら　全て忘れます
Dialogue: 0,0:20:17.14,0:20:21.23,Dial_JP,,0,0,0,,あなたを忘れる　この悲しみすら忘れる
Dialogue: 0,0:20:25.33,0:20:27.14,Dial_JP,,0,0,0,,ならば　剣を手に
Dialogue: 0,0:20:43.19,0:20:44.73,Dial_JP,,0,0,0,,皆が忘れようと
Dialogue: 0,0:20:45.30,0:20:48.00,Dial_JP,,0,0,0,,忘却の神たるわたくしだけは忘れない
Dialogue: 0,0:20:48.93,0:20:53.60,Dial_JP,,0,0,0,,やがて世界が終焉を迎える　そのときまで
Dialogue: 0,0:20:57.14,0:21:01.74,Dial_JP,,0,0,0,,この黄昏の楽園に　わたくしは君臨し続ける
Dialogue: 0,0:26:35.79,0:26:36.25,Dial_JP,,0,0,0,,ちょ
Dialogue: 0,0:26:36.25,0:26:37.34,Dial_JP,,0,0,0,,真ん中
Dialogue: 0,0:26:40.50,0:26:41.29,Dial_JP,,0,0,0,,立希ちゃん
Dialogue: 0,0:26:41.29,0:26:42.61,Dial_JP,,0,0,0,,挨拶するよ
Dialogue: 0,0:26:53.89,0:26:55.64,Dial_JP,,0,0,0,,ありがとうございました
Dialogue: 1,0:00:04.05,0:00:05.78,Dial_CH,,0,0,0,,豐川同學 到時間了
Dialogue: 1,0:00:10.18,0:00:11.38,Dial_CH,,0,0,0,,走吧
Dialogue: 1,0:00:12.58,0:00:14.49,Dial_CH,,0,0,0,,來圍個圓陣吧
Dialogue: 1,0:00:14.49,0:00:16.10,Dial_CH,,0,0,0,,都該出場了
Dialogue: 1,0:00:16.10,0:00:17.83,Dial_CH,,0,0,0,,要搞就快點
Dialogue: 1,0:00:17.83,0:00:19.75,Dial_CH,,0,0,0,,狸希也來
Dialogue: 1,0:00:19.75,0:00:21.21,Dial_CH,,0,0,0,,加油
Dialogue: 1,0:00:21.21,0:00:22.16,Dial_CH,,0,0,0,,My…
Dialogue: 1,0:00:22.16,0:00:23.47,Dial_CH,,0,0,0,,該燈喊口號吧
Dialogue: 1,0:00:24.51,0:00:25.66,Dial_CH,,0,0,0,,那 燈燈
Dialogue: 1,0:00:26.23,0:00:28.26,Dial_CH,,0,0,0,,就喊「MyGO」
Dialogue: 1,0:00:30.11,0:00:31.02,Dial_CH,,0,0,0,,那就…
Dialogue: 1,0:00:31.34,0:00:33.01,Dial_CH,,0,0,0,,MyGO
Dialogue: 1,0:00:32.24,0:00:33.30,Dial_CH,,0,1000,0,,等下等下
Dialogue: 1,0:00:33.30,0:00:34.15,Dial_CH,,0,0,0,,{\fad(0,360)}GO
Dialogue: 1,0:00:34.46,0:00:36.95,Dial_CH,,0,0,0,,今日 今夜晚僅此一回
Dialogue: 1,0:00:37.54,0:00:38.59,Dial_CH,,0,0,0,,{\pos(960,1030)}採擷今日
Dialogue: 1,0:00:38.99,0:00:40.60,Dial_CH,,0,0,0,,摘下今日之花
Dialogue: 1,0:00:40.82,0:00:43.54,Dial_CH,,0,0,0,,沉溺於今夜短暫的享樂吧
Dialogue: 1,0:00:43.54,0:00:44.65,Dial_CH,,0,0,0,,享樂嗎
Dialogue: 1,0:00:44.65,0:00:46.48,Dial_CH,,0,0,0,,好像幹壞事一樣
Dialogue: 1,0:00:49.11,0:00:51.38,Dial_CH,,0,0,0,,那就好好享受吧
Dialogue: 1,0:00:52.13,0:00:53.83,Dial_CH,,0,0,15,,Ave Mujica
Dialogue: 1,0:00:53.83,0:00:55.54,Dial_CH,,0,0,0,,再來次 再來次
Dialogue: 1,0:00:55.54,0:00:57.29,Dial_CH,,0,0,0,,「GO」都沒喊齊
Dialogue: 1,0:00:57.29,0:00:58.50,Dial_CH,,0,0,0,,下次再說吧
Dialogue: 1,0:00:58.50,0:01:00.42,Dial_CH,,0,0,0,,下次是什麼時候呀
Dialogue: 1,0:01:01.34,0:01:02.55,Dial_CH,,0,0,0,,現在不許吃
Dialogue: 1,0:01:05.46,0:01:07.71,Dial_CH,,0,0,0,,燈在醞釀情緒
Dialogue: 1,0:01:11.60,0:01:13.42,Dial_CH,,0,0,0,,走吧 狸希
Dialogue: 1,0:05:19.98,0:05:22.65,Dial_CH,,0,0,0,,清晨 桂花香氣飄來
Dialogue: 1,0:05:23.25,0:05:25.93,Dial_CH,,0,0,0,,小愛幫我找到了開花之處
Dialogue: 1,0:05:26.66,0:05:28.47,Dial_CH,,0,0,0,,樹冠漏下的陽光多麼溫柔
Dialogue: 1,0:05:31.60,0:05:34.54,Dial_CH,,0,0,0,,練習室中我準備筆記本的時候
Dialogue: 1,0:05:34.93,0:05:36.82,Dial_CH,,0,0,0,,背後傳來立希的聲音
Dialogue: 1,0:05:38.00,0:05:42.41,Dial_CH,,0,0,0,,練習之前的咚咚聲 讓人安心
Dialogue: 1,0:05:43.12,0:05:46.07,Dial_CH,,0,0,0,,和樂奈一起吃了金平糖
Dialogue: 1,0:05:46.64,0:05:49.74,Dial_CH,,0,0,0,,她大口嚼著綠色的
Dialogue: 1,0:05:50.16,0:05:51.81,Dial_CH,,0,0,0,,說「這不是抹茶味的」
Dialogue: 1,0:05:51.81,0:05:53.36,Dial_CH,,0,0,0,,是蜜瓜味
Dialogue: 1,0:05:54.30,0:05:56.64,Dial_CH,,0,0,0,,剛才步履蹣跚時
Dialogue: 1,0:05:56.98,0:05:59.59,Dial_CH,,0,0,0,,爽世牽住了我的手
Dialogue: 1,0:05:59.95,0:06:03.97,Dial_CH,,0,0,0,,她的手 比之前更冷一些
Dialogue: 1,0:06:05.13,0:06:07.06,Dial_CH,,0,0,0,,季節已經改變
Dialogue: 1,0:06:10.21,0:06:11.07,Dial_CH,,0,0,0,,燈燈
Dialogue: 1,0:16:05.22,0:16:07.39,Dial_CH,,0,0,0,,這裡是樂園？
Dialogue: 1,0:16:08.29,0:16:09.20,Dial_CH,,0,0,0,,新來的嗎
Dialogue: 1,0:16:09.59,0:16:12.49,Dial_CH,,0,0,0,,我是悲傷騎士 Doloris
Dialogue: 1,0:16:12.49,0:16:15.77,Dial_CH,,0,0,0,,前來侍奉女神 Oblivionis
Dialogue: 1,0:16:17.02,0:16:20.04,Dial_CH,,0,0,0,,原來除了我們 還有別的好事者啊
Dialogue: 1,0:16:20.04,0:16:22.25,Dial_CH,,0,0,0,,我們也一樣 Doloris
Dialogue: 1,0:16:22.57,0:16:24.94,Dial_CH,,0,0,0,,我是恐懼騎士 Timoris
Dialogue: 1,0:16:24.94,0:16:26.83,Dial_CH,,0,0,0,,愛之騎士 Amoris
Dialogue: 1,0:16:27.03,0:16:28.38,Dial_CH,,0,0,0,,然後那邊是…
Dialogue: 1,0:16:28.89,0:16:29.94,Dial_CH,,0,0,0,,妳在幹嘛呢
Dialogue: 1,0:16:30.45,0:16:31.36,Dial_CH,,0,0,0,,我在聽
Dialogue: 1,0:16:31.36,0:16:32.71,Dial_CH,,0,0,0,,就是問妳在聽什麼
Dialogue: 1,0:16:34.19,0:16:36.05,Dial_CH,,0,0,0,,世界毀壞的聲音
Dialogue: 1,0:16:36.27,0:16:39.01,Dial_CH,,0,0,0,,死亡騎士 Mortis 是個怪傢伙
Dialogue: 1,0:16:40.06,0:16:41.51,Dial_CH,,0,0,0,,妳不用擔心
Dialogue: 1,0:16:41.77,0:16:43.65,Dial_CH,,0,0,0,,只要待在這裡 就不會有可怕的事
Dialogue: 1,0:16:43.65,0:16:45.30,Dial_CH,,0,0,0,,我可以向妳保證
Dialogue: 1,0:16:46.75,0:16:48.66,Dial_CH,,0,0,0,,就會說些隨意的承諾
Dialogue: 1,0:16:48.66,0:16:50.01,Dial_CH,,0,0,0,,妳說誰隨意
Dialogue: 1,0:16:50.57,0:16:52.87,Dial_CH,,0,0,0,,這裡不過是如泡沫般的盆景
Dialogue: 1,0:16:54.30,0:16:56.74,Dial_CH,,0,0,0,,在世界毀壞之前
Dialogue: 1,0:16:56.74,0:17:00.17,Dial_CH,,0,0,0,,只需要快樂舞動 輕鬆生活
Dialogue: 1,0:17:03.25,0:17:05.60,Dial_CH,,0,0,0,,充滿欺瞞的樂園
Dialogue: 1,0:17:10.24,0:17:13.35,Dial_CH,,0,0,0,,Oblivionis 並不在 很遺憾
Dialogue: 1,0:17:14.18,0:17:16.56,Dial_CH,,0,0,0,,據說她消失有一段時間了
Dialogue: 1,0:17:16.56,0:17:17.75,Dial_CH,,0,0,0,,怎麼會
Dialogue: 1,0:17:18.23,0:17:20.26,Dial_CH,,0,0,0,,我們也一直在祈願
Dialogue: 1,0:17:21.09,0:17:23.36,Dial_CH,,0,0,0,,願她有一天回到樂園
Dialogue: 1,0:17:23.99,0:17:26.30,Dial_CH,,0,0,0,,賦予我們忘卻
Dialogue: 1,0:17:28.00,0:17:31.69,Dial_CH,,0,0,0,,我的生命 建立在無數死亡之上
Dialogue: 1,0:17:32.46,0:17:36.30,Dial_CH,,0,0,0,,並非我所願 而是為了生存
Dialogue: 1,0:17:37.07,0:17:40.38,Dial_CH,,0,0,0,,昨天一次 今天一次
Dialogue: 1,0:17:41.59,0:17:45.09,Dial_CH,,0,0,0,,我希望把它們都忘記
Dialogue: 1,0:17:46.47,0:17:48.30,Dial_CH,,0,0,0,,世界毀壞的聲音？
Dialogue: 1,0:17:48.73,0:17:50.42,Dial_CH,,0,0,0,,我聽不見
Dialogue: 1,0:17:50.86,0:17:53.43,Dial_CH,,0,0,0,,為什麼 為什麼她聽得到
Dialogue: 1,0:17:53.67,0:17:58.51,Dial_CH,,0,0,0,,讓我忘記那份嫉妒到憎恨的愛吧
Dialogue: 1,0:17:59.50,0:18:01.27,Dial_CH,,0,0,0,,沒有人相信我
Dialogue: 1,0:18:01.27,0:18:02.74,Dial_CH,,0,0,0,,沒人願意相信我
Dialogue: 1,0:18:03.21,0:18:06.14,Dial_CH,,0,0,0,,我多想忘掉這份恐懼
Dialogue: 1,0:18:07.55,0:18:10.27,Dial_CH,,0,0,0,,而我們 只能祈願
Dialogue: 1,0:18:10.27,0:18:11.44,Dial_CH,,0,0,0,,我不要
Dialogue: 1,0:18:11.44,0:18:13.49,Dial_CH,,0,0,0,,我已經承受不住
Dialogue: 1,0:18:13.79,0:18:15.62,Dial_CH,,0,0,0,,我充滿罪孽
Dialogue: 1,0:18:15.94,0:18:18.37,Dial_CH,,0,0,0,,存在本身就是罪過
Dialogue: 1,0:18:18.37,0:18:21.37,Dial_CH,,0,0,0,,我想要全部忘記 得到救贖
Dialogue: 1,0:18:21.37,0:18:22.62,Dial_CH,,0,0,0,,靠愛不行嗎
Dialogue: 1,0:18:22.82,0:18:23.75,Dial_CH,,0,0,0,,不行
Dialogue: 1,0:18:23.75,0:18:24.82,Dial_CH,,0,0,0,,恐懼呢
Dialogue: 1,0:18:25.00,0:18:26.13,Dial_CH,,0,0,0,,不對
Dialogue: 1,0:18:26.33,0:18:27.31,Dial_CH,,0,0,0,,給妳死亡
Dialogue: 1,0:18:27.63,0:18:28.71,Dial_CH,,0,0,0,,不需要
Dialogue: 1,0:18:29.13,0:18:32.91,Dial_CH,,0,0,0,,不是愛 不是恐懼 不是死亡 不是悲傷
Dialogue: 1,0:18:33.97,0:18:38.31,Dial_CH,,0,0,0,,唯獨忘卻 能拯救我於這痛苦之中
Dialogue: 1,0:18:40.26,0:18:41.52,Dial_CH,,0,0,0,,真的嗎？
Dialogue: 1,0:18:42.82,0:18:43.82,Dial_CH,,0,0,0,,這聲音…
Dialogue: 1,0:18:44.31,0:18:47.06,Dial_CH,,0,0,0,,忘卻就是妳來到此處的理由？
Dialogue: 1,0:18:47.06,0:18:51.35,Dial_CH,,0,0,0,,又來了 總是縈繞耳邊的話語
Dialogue: 1,0:18:51.35,0:18:52.51,Dial_CH,,0,0,0,,Doloris
Dialogue: 1,0:18:53.54,0:18:55.95,Dial_CH,,0,0,0,,妳真正的願望是什麼？
Dialogue: 1,0:19:02.57,0:19:03.34,Dial_CH,,0,0,0,,難道是…
Dialogue: 1,0:19:03.59,0:19:04.89,Dial_CH,,0,0,0,,Oblivionis？
Dialogue: 1,0:19:07.98,0:19:09.21,Dial_CH,,0,0,0,,忘卻女神
Dialogue: 1,0:19:09.71,0:19:12.02,Dial_CH,,0,0,0,,請允許我做您的騎士
Dialogue: 1,0:19:26.24,0:19:27.09,Dial_CH,,0,0,0,,等一下
Dialogue: 1,0:19:27.44,0:19:29.14,Dial_CH,,0,0,0,,也讓我做妳的騎士
Dialogue: 1,0:19:29.14,0:19:30.49,Dial_CH,,0,0,0,,賜予我忘卻的福音
Dialogue: 1,0:19:30.49,0:19:32.11,Dial_CH,,0,0,0,,要重複多少次
Dialogue: 1,0:19:33.37,0:19:37.74,Dial_CH,,0,0,0,,不管多少次賜予妳忘卻 妳都會回到樂園
Dialogue: 1,0:19:38.01,0:19:39.27,Dial_CH,,0,0,0,,妳說什麼
Dialogue: 1,0:19:39.81,0:19:42.25,Dial_CH,,0,0,0,,我今天第一次來到這裡
Dialogue: 1,0:19:42.25,0:19:43.37,Dial_CH,,0,0,0,,真的嗎？
Dialogue: 1,0:19:45.46,0:19:47.76,Dial_CH,,0,0,0,,回想起來 Doloris
Dialogue: 1,0:19:48.22,0:19:50.46,Dial_CH,,0,0,0,,妳來過這裡多少次？
Dialogue: 1,0:19:51.81,0:19:54.85,Dial_CH,,0,0,0,,妳為何知曉 Oblivionis 之名？
Dialogue: 1,0:19:56.10,0:19:58.97,Dial_CH,,0,0,0,,又為何尋求忘卻？
Dialogue: 1,0:20:00.15,0:20:02.11,Dial_CH,,0,0,0,,我只是想見到她…
Dialogue: 1,0:20:02.62,0:20:04.69,Dial_CH,,0,0,0,,妳不是我的騎士
Dialogue: 1,0:20:11.06,0:20:12.62,Dial_CH,,0,0,0,,我會忘記妳
Dialogue: 1,0:20:12.86,0:20:16.39,Dial_CH,,0,0,0,,只要能留在妳身邊 我全都可以忘記
Dialogue: 1,0:20:17.14,0:20:21.23,Dial_CH,,0,0,0,,連忘記妳的悲傷 我也可以忘記
Dialogue: 1,0:20:25.33,0:20:27.14,Dial_CH,,0,0,0,,那就拿起妳的劍
Dialogue: 1,0:20:43.19,0:20:44.73,Dial_CH,,0,0,0,,大家都想忘記
Dialogue: 1,0:20:45.30,0:20:48.00,Dial_CH,,0,0,0,,唯獨忘卻之神的我 不會忘記
Dialogue: 1,0:20:48.93,0:20:53.60,Dial_CH,,0,0,0,,直至世界有朝一日迎來終焉
Dialogue: 1,0:20:57.14,0:21:01.74,Dial_CH,,0,0,0,,我將一直君臨這黃昏樂園
Dialogue: 1,0:26:35.79,0:26:36.25,Dial_CH,,0,0,0,,喂
Dialogue: 1,0:26:36.25,0:26:37.34,Dial_CH,,0,0,0,,正中間
Dialogue: 1,0:26:40.50,0:26:41.29,Dial_CH,,0,0,0,,立希
Dialogue: 1,0:26:41.29,0:26:42.61,Dial_CH,,0,0,0,,該致謝了
Dialogue: 1,0:26:53.89,0:26:55.64,Dial_CH,,0,0,0,,謝謝大家
Dialogue: 1,0:00:37.54,0:00:38.59,Dial_CH,,0,0,0,,{\an5\fs49\pos(960,945)}Carpe diem
Dialogue: 1,0:16:05.22,0:16:07.39,Dial_CH,,0,0,0,,{\an5\fs49\pos(1012,945)}Paradisus
Dialogue: 0,0:00:11.49,0:00:12.58,Screen2,,0,0,0,,{\pos(960,54)\c&H615951&\fsp8}諸神黃昏
Dialogue: 0,0:00:58.45,0:01:00.08,Screen,,0,0,0,,{\fax0.35\bord2\shad2\c&H080808&\4c&H101A25&\3c&H242426&\pos(776,634)\frz337.1}大家請隨意品嘗！
Dialogue: 0,0:01:16.89,0:01:19.73,Title,,0,0,0,,{\alpha&H11&\fad(1200,400)\blur0.6\pos(1483,850)}#13 穿越逆境終達星辰。
Dialogue: 0,0:26:55.64,0:26:59.97,Staff,,0,0,0,,{\fad(1000,0)\fnHYXuanSong 65S\bord0.2\shad0\blur3\c&HFFFFFF&}本字幕由喵萌Production製作  僅供交流試看之用  請勿用於商業用途\N翻譯·時軸：Ronny　後期：MIR　繁化：錯黨
Dialogue: 0,0:01:37.45,0:01:39.42,Dial_JP,,0,0,0,,こころ写す言葉
Dialogue: 0,0:01:39.42,0:01:41.87,Dial_JP,,0,0,0,,剥がして連れて行って
Dialogue: 0,0:01:42.62,0:01:44.67,Dial_JP,,0,0,0,,わかれ道の先へ
Dialogue: 0,0:01:44.67,0:01:47.05,Dial_JP,,0,0,0,,僕らは歩き出す
Dialogue: 0,0:01:47.99,0:01:49.99,Dial_JP,,0,0,0,,どうしたらいいのか
Dialogue: 0,0:01:49.99,0:01:53.26,Dial_JP,,0,0,0,,巡らせてる間に
Dialogue: 0,0:01:53.26,0:01:55.80,Dial_JP,,0,0,0,,季節も変わるよ
Dialogue: 0,0:01:55.80,0:01:58.07,Dial_JP,,0,0,0,,僕もそうかな
Dialogue: 0,0:01:58.60,0:02:03.77,Dial_JP,,0,0,0,,ゆらゆら　今日も曲がり角に立つ
Dialogue: 0,0:02:03.77,0:02:08.98,Dial_JP,,0,0,0,,右左どっちも選べないまま
Dialogue: 0,0:02:08.98,0:02:14.33,Dial_JP,,0,0,0,,ふらふらな僕の行方はわからない
Dialogue: 0,0:02:14.33,0:02:19.07,Dial_JP,,0,0,0,,だけどちょっと先へ行くつもりさ
Dialogue: 0,0:02:19.07,0:02:24.51,Dial_JP,,0,0,0,,筋書きのない日々を生きてく僕らは
Dialogue: 0,0:02:24.51,0:02:29.80,Dial_JP,,0,0,0,,慣れない感情に　うろたえてる
Dialogue: 0,0:02:29.80,0:02:36.18,Dial_JP,,0,0,0,,傷ついても　もしまた　傷つけたとしても
Dialogue: 0,0:02:36.18,0:02:42.58,Dial_JP,,0,0,0,,僕のままで　ここにいたいから
Dialogue: 0,0:02:51.44,0:02:53.28,Dial_JP,,0,0,0,,自分のことも
Dialogue: 0,0:02:53.28,0:02:55.67,Dial_JP,,0,0,0,,まるでわからないのに
Dialogue: 0,0:02:56.30,0:02:58.35,Dial_JP,,0,0,0,,それでも君のこと
Dialogue: 0,0:02:58.35,0:03:01.07,Dial_JP,,0,0,0,,わかりたかったんだよ
Dialogue: 0,0:03:01.95,0:03:03.78,Dial_JP,,0,0,0,,手のひらにのせた
Dialogue: 0,0:03:03.78,0:03:06.85,Dial_JP,,0,0,0,,便箋はあたたかい
Dialogue: 0,0:03:06.85,0:03:11.97,Dial_JP,,0,0,0,,君と手つないでいるみたいで
Dialogue: 0,0:03:12.46,0:03:17.64,Dial_JP,,0,0,0,,くらくらしては　まぶたを閉じてさ
Dialogue: 0,0:03:17.64,0:03:22.72,Dial_JP,,0,0,0,,巻き戻し昨日を映すたびに
Dialogue: 0,0:03:22.72,0:03:28.07,Dial_JP,,0,0,0,,ぽろぽろと今がこぼれ落ちるなら
Dialogue: 0,0:03:28.07,0:03:32.98,Dial_JP,,0,0,0,,僕は目を開けてみつめなくちゃ
Dialogue: 0,0:03:32.98,0:03:38.39,Dial_JP,,0,0,0,,もう戻らない　欠片を集めてみても
Dialogue: 0,0:03:38.39,0:03:43.75,Dial_JP,,0,0,0,,二度と同じ瞬間(とき)に　帰れなくて
Dialogue: 0,0:03:43.75,0:03:49.92,Dial_JP,,0,0,0,,足踏みして　進めずいると想ってたけど
Dialogue: 0,0:03:49.92,0:03:55.38,Dial_JP,,0,0,0,,新しい風に吹かれてた
Dialogue: 0,0:03:55.38,0:04:04.29,Dial_JP,,0,0,0,,はぐれた道が　もう一度この先でもしも交わるなら
Dialogue: 0,0:04:04.29,0:04:06.82,Dial_JP,,0,0,0,,うつむかずうたうよ
Dialogue: 0,0:04:06.82,0:04:09.55,Dial_JP,,0,0,0,,君を見つけたいから
Dialogue: 0,0:04:09.55,0:04:12.32,Dial_JP,,0,0,0,,ひだまりのように
Dialogue: 0,0:04:12.32,0:04:18.90,Dial_JP,,0,0,0,,笑っててほしくて　ああ
Dialogue: 0,0:04:28.83,0:04:33.71,Dial_JP,,0,0,0,,僕らにしか迷えないたった今を
Dialogue: 0,0:04:33.71,0:04:38.80,Dial_JP,,0,0,0,,忘れたくないから　うたっている
Dialogue: 0,0:04:38.80,0:04:45.25,Dial_JP,,0,0,0,,優しい君が君のままでいられるように
Dialogue: 0,0:04:45.25,0:04:49.50,Dial_JP,,0,0,0,,この声にこめた
Dialogue: 0,0:04:49.50,0:04:54.82,Dial_JP,,0,0,0,,筋書きのない日々を生きてく僕らは
Dialogue: 0,0:04:54.82,0:04:59.97,Dial_JP,,0,0,0,,絶えない不安の中を踏み出してく
Dialogue: 0,0:04:59.97,0:05:06.38,Dial_JP,,0,0,0,,傷ついても　もしまた　傷つけたとしても
Dialogue: 0,0:05:06.38,0:05:13.18,Dial_JP,,0,0,0,,僕はここで　うたっているから
Dialogue: 1,0:01:37.45,0:01:39.42,Dial_CH,,0,0,0,,將描繪心靈的話語
Dialogue: 1,0:01:39.42,0:01:41.87,Dial_CH,,0,0,0,,撕下一頁隨身攜帶
Dialogue: 1,0:01:42.62,0:01:44.67,Dial_CH,,0,0,0,,我們向著岔路前方
Dialogue: 1,0:01:44.67,0:01:47.05,Dial_CH,,0,0,0,,邁出了啟程的步伐
Dialogue: 1,0:01:47.99,0:01:49.99,Dial_CH,,0,0,0,,我到底該如何是好
Dialogue: 1,0:01:49.99,0:01:53.26,Dial_CH,,0,0,0,,就在猶豫不決之間
Dialogue: 1,0:01:53.26,0:01:55.80,Dial_CH,,0,0,0,,季節也會悄然改變
Dialogue: 1,0:01:55.80,0:01:58.07,Dial_CH,,0,0,0,,而我是否也一樣呢
Dialogue: 1,0:01:58.60,0:02:03.77,Dial_CH,,0,0,0,,搖搖晃晃 今天我也站在街角
Dialogue: 1,0:02:03.77,0:02:08.98,Dial_CH,,0,0,0,,不知該向左還是向右
Dialogue: 1,0:02:08.98,0:02:14.33,Dial_CH,,0,0,0,,稀裡糊塗 我找不到行進方向
Dialogue: 1,0:02:14.33,0:02:19.07,Dial_CH,,0,0,0,,但我依然要稍微前行
Dialogue: 1,0:02:19.07,0:02:24.51,Dial_CH,,0,0,0,,我們的生活一向沒有大綱
Dialogue: 1,0:02:24.51,0:02:29.80,Dial_CH,,0,0,0,,不習慣的感情 讓我們慌慌張張
Dialogue: 1,0:02:29.80,0:02:36.18,Dial_CH,,0,0,0,,就算受傷 甚至傷害到他人
Dialogue: 1,0:02:36.18,0:02:42.58,Dial_CH,,0,0,0,,我也希望在此 做好自己
Dialogue: 1,0:02:51.44,0:02:53.28,Dial_CH,,0,0,0,,自己是什麼樣的人
Dialogue: 1,0:02:53.28,0:02:55.67,Dial_CH,,0,0,0,,我已經絲毫不明白
Dialogue: 1,0:02:56.30,0:02:58.35,Dial_CH,,0,0,0,,可你是什麼樣的人
Dialogue: 1,0:02:58.35,0:03:01.07,Dial_CH,,0,0,0,,我卻如此渴望得知
Dialogue: 1,0:03:01.95,0:03:03.78,Dial_CH,,0,0,0,,我掌中的那枚信紙
Dialogue: 1,0:03:03.78,0:03:06.85,Dial_CH,,0,0,0,,散發著一片片暖意
Dialogue: 1,0:03:06.85,0:03:11.97,Dial_CH,,0,0,0,,彷彿緊牽著你的手
Dialogue: 1,0:03:12.46,0:03:17.64,Dial_CH,,0,0,0,,暈暈乎乎 每當我閉上了雙眼
Dialogue: 1,0:03:17.64,0:03:22.72,Dial_CH,,0,0,0,,昨日的回憶如倒帶般浮現
Dialogue: 1,0:03:22.72,0:03:28.07,Dial_CH,,0,0,0,,滴滴答答 既然此刻不斷落下
Dialogue: 1,0:03:28.07,0:03:32.98,Dial_CH,,0,0,0,,我知道我必須要睜眼凝視
Dialogue: 1,0:03:32.98,0:03:38.39,Dial_CH,,0,0,0,,無法拼起的碎片 再怎麼收集
Dialogue: 1,0:03:38.39,0:03:43.75,Dial_CH,,0,0,0,,我們也不會回到同樣的瞬間
Dialogue: 1,0:03:43.75,0:03:49.92,Dial_CH,,0,0,0,,本以為我在原地踏步 裹足不前
Dialogue: 1,0:03:49.92,0:03:55.38,Dial_CH,,0,0,0,,其實是一陣新風迎面吹來
Dialogue: 1,0:03:55.38,0:04:04.29,Dial_CH,,0,0,0,,若分開的道路 會在前方重新相交
Dialogue: 1,0:04:04.29,0:04:06.82,Dial_CH,,0,0,0,,我將會昂首歌唱
Dialogue: 1,0:04:06.82,0:04:09.55,Dial_CH,,0,0,0,,只為將你放在眼中
Dialogue: 1,0:04:09.55,0:04:12.32,Dial_CH,,0,0,0,,希望你能溫暖我
Dialogue: 1,0:04:12.32,0:04:18.90,Dial_CH,,0,0,0,,給我陽光般的笑容
Dialogue: 1,0:04:28.83,0:04:33.71,Dial_CH,,0,0,0,,如今只屬於我們的迷茫
Dialogue: 1,0:04:33.71,0:04:38.80,Dial_CH,,0,0,0,,我不願忘卻 因而歌唱
Dialogue: 1,0:04:38.80,0:04:45.25,Dial_CH,,0,0,0,,願溫柔的你 能永遠做你自己
Dialogue: 1,0:04:45.25,0:04:49.50,Dial_CH,,0,0,0,,將這願望融入歌聲
Dialogue: 1,0:04:49.50,0:04:54.82,Dial_CH,,0,0,0,,我們的生活一向沒有大綱
Dialogue: 1,0:04:54.82,0:04:59.97,Dial_CH,,0,0,0,,在接踵而至的不安中邁步前行
Dialogue: 1,0:04:59.97,0:05:06.38,Dial_CH,,0,0,0,,即便受傷 甚至傷害到他人
Dialogue: 1,0:05:06.38,0:05:13.18,Dial_CH,,0,0,0,,我依然在此處 放聲歌唱
Dialogue: 0,0:06:20.18,0:06:22.23,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}きっと理由は　バラバラだった
Dialogue: 0,0:06:22.65,0:06:24.80,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}寄る辺のない　あの日の僕たち
Dialogue: 0,0:06:25.37,0:06:27.27,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}もう二度と傷つきたくないって
Dialogue: 0,0:06:27.27,0:06:29.11,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}そう思って　うつむいたのに
Dialogue: 0,0:06:29.66,0:06:31.20,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}迷ってたから出会えて
Dialogue: 0,0:06:31.20,0:06:32.64,IN_JP_EP13_TANEBI_INTRO,,720,0,0,,{\blur3\fad(180,180)}やっと繋いだ手を
Dialogue: 0,0:06:32.64,0:06:34.08,IN_JP_EP13_TANEBI_INTRO,,720,0,0,,{\blur3\fad(180,180)}もう僕は離さない
Dialogue: 0,0:06:34.54,0:06:37.38,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}何があっても　握りしめていく
Dialogue: 0,0:06:57.83,0:06:59.78,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}正解なんてわからなくて
Dialogue: 0,0:06:59.78,0:07:01.73,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}転んでまた痛みを知った
Dialogue: 0,0:07:01.73,0:07:03.51,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}それでも立ち上がった君を
Dialogue: 0,0:07:03.51,0:07:04.83,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}笑うはずなんてない
Dialogue: 0,0:07:04.83,0:07:07.70,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}行き止まりばかりでも　また道を探す
Dialogue: 0,0:07:07.70,0:07:10.93,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}この音で響き合うため　ここに立つため
Dialogue: 0,0:07:10.93,0:07:12.23,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}ぶつかりながら
Dialogue: 0,0:07:11.95,0:07:14.40,IN_JP_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}何度も
Dialogue: 0,0:07:12.23,0:07:15.08,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}心の中に　瞬間灯った
Dialogue: 0,0:07:15.08,0:07:17.58,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}小さな火　消さないでいて
Dialogue: 0,0:07:17.58,0:07:20.69,IN_JP_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}消えない
Dialogue: 0,0:07:17.91,0:07:20.02,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}意味とか行き先とかまだない
Dialogue: 0,0:07:20.02,0:07:22.88,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}完璧なんて　ほど遠い僕たちだけど
Dialogue: 0,0:07:22.88,0:07:25.47,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}この音色でしか　{\3c&HAA7777&}たき{\3c&H2051ED&}つけられない
Dialogue: 0,0:07:25.47,0:07:27.18,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}胸がいま騒ぎ出して
Dialogue: 0,0:07:27.93,0:07:30.26,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}こころのまんなかに
Dialogue: 0,0:07:29.62,0:07:34.37,IN_JP_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}oh まんなかに
Dialogue: 0,0:07:30.26,0:07:33.21,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}宿すうたを　{\3c&HDDBB77&}ともり{\3c&H2051ED&}びに
Dialogue: 0,0:07:33.21,0:07:37.12,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}僕たちの音鳴らしていたいよ
Dialogue: 0,0:07:37.12,0:07:40.22,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}明日はね　遠いけど
Dialogue: 0,0:07:40.22,0:07:45.14,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}たった今ここに立つ僕たちを照らそう
Dialogue: 0,0:07:45.14,0:07:50.90,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(0,360)}迷うことに迷わないでいいよ
Dialogue: 0,0:07:52.13,0:07:55.62,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(360,360)}It’s our sound
Dialogue: 0,0:08:08.64,0:08:10.62,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}言葉になんてしたところで
Dialogue: 0,0:08:10.85,0:08:12.68,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}戸惑う人の目が怖かった
Dialogue: 0,0:08:12.68,0:08:14.25,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}それでも抱えた声を
Dialogue: 0,0:08:14.25,0:08:15.85,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}受け止めてくれた音楽
Dialogue: 0,0:08:15.85,0:08:18.31,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}こぼれた涙さえ　ここじゃあたたかく
Dialogue: 0,0:08:18.31,0:08:20.46,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}ほ{\3c&H77DD77&}らあな{\3c&H2051ED&}のライブハウスに
Dialogue: 0,0:08:20.46,0:08:21.56,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}打ち鳴らすたび
Dialogue: 0,0:08:21.56,0:08:22.88,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}咲いた熱は
Dialogue: 0,0:08:22.61,0:08:25.03,IN_JP_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}消えない
Dialogue: 0,0:08:22.88,0:08:25.90,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}分け合う種火　共振するんだ
Dialogue: 0,0:08:25.90,0:08:28.45,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}宿火よ　君を照らせ
Dialogue: 0,0:08:28.45,0:08:31.28,IN_JP_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}かざせ
Dialogue: 0,0:08:28.73,0:08:30.48,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}それぞれの拳の中に
Dialogue: 0,0:08:30.77,0:08:33.04,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}握ってるものは　違ったっていいんだよ
Dialogue: 0,0:08:33.54,0:08:38.19,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}このパンクロックの中で同じ熱になれるいまがすべて
Dialogue: 0,0:08:38.55,0:08:41.02,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}この喉を鳴らして
Dialogue: 0,0:08:40.42,0:08:45.07,IN_JP_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}oh 鳴らして
Dialogue: 0,0:08:41.02,0:08:43.96,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}音にいだかれたあの日に
Dialogue: 0,0:08:43.96,0:08:47.83,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}震える胸に宿した青い炎
Dialogue: 0,0:08:47.83,0:08:51.01,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\3c&H88DDFF&}そよ{\3c&H2051ED&}ぐはずない風に
Dialogue: 0,0:08:51.01,0:08:55.74,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}吹かれてる箱の中　自由に飛べるだろう
Dialogue: 0,0:08:55.74,0:09:01.65,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(0,360)}君とならどこまでもいきたいよ
Dialogue: 0,0:09:07.86,0:09:11.92,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(360,360)}It’s our sound
Dialogue: 0,0:09:22.06,0:09:32.11,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(240,240)}It’s the blazing our sound. We all sing out with the same heat.
Dialogue: 0,0:09:32.11,0:09:42.01,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(240,240)}We will go with our song. Yet still tomorrow is {\3c&H9988FF&}unknown{\3c&H2051ED&}.
Dialogue: 0,0:09:42.01,0:09:46.22,IN_JP_EP13_TANEBI_MAIN,,0,0,60,,{\blur3}暗闇の中でも今は　一緒に迷ってくれる人がいる
Dialogue: 0,0:09:46.45,0:09:50.63,IN_JP_EP13_TANEBI_MAIN,,0,0,60,,{\blur3}それでも一人になる日には　このうたを灯して歩く
Dialogue: 0,0:09:51.26,0:09:54.17,IN_JP_EP13_TANEBI_MAIN,,0,0,60,,{\blur3}また傷つくよ　この先でも
Dialogue: 0,0:09:54.71,0:09:57.14,IN_JP_EP13_TANEBI_MAIN,,0,0,60,,{\blur3}それでも離したくない手があって
Dialogue: 0,0:09:57.41,0:09:59.37,IN_JP_EP13_TANEBI_MAIN,,0,0,60,,{\blur3}はぐれてもあきらめないよ
Dialogue: 0,0:09:59.37,0:10:01.81,IN_JP_EP13_TANEBI_MAIN,,0,0,60,,{\blur3}転んでも君みたいに立ち上がる
Dialogue: 0,0:10:02.22,0:10:05.22,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}大丈夫　僕たちは進もう
Dialogue: 0,0:10:06.21,0:10:09.94,IN_JP_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}迷うことに　もう迷わない
Dialogue: 2,0:09:42.01,0:09:52.26,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\alpha&88&\fad(240,240)}It’s the blazing our sound. We all sing out with the same heat.
Dialogue: 2,0:09:52.26,0:10:02.02,IN_JP_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\alpha&88&\fad(240,240)}We will go with our song. Yet still tomorrow is unknown.
Dialogue: 1,0:06:20.18,0:06:22.23,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}當初的理由想必各不相同
Dialogue: 1,0:06:22.65,0:06:24.80,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}那一天的我們無依無靠
Dialogue: 1,0:06:25.37,0:06:27.27,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}抱著不想再受傷的念頭
Dialogue: 1,0:06:27.27,0:06:29.11,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}我們低頭俯視著地面
Dialogue: 1,0:06:29.66,0:06:31.20,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}卻依然因迷路而邂逅
Dialogue: 1,0:06:31.20,0:06:32.64,IN_CH_EP13_TANEBI_INTRO,,720,0,0,,{\blur3\fad(180,180)}好不容易牽起的手
Dialogue: 1,0:06:32.64,0:06:34.08,IN_CH_EP13_TANEBI_INTRO,,720,0,0,,{\blur3\fad(180,180)}我不會再放開
Dialogue: 1,0:06:34.54,0:06:37.38,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3\fad(180,180)}不論發生什麼 只會攥得更緊
Dialogue: 1,0:06:57.83,0:06:59.78,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}我不知道什麼是正確答案
Dialogue: 1,0:06:59.78,0:07:01.73,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}每次摔倒都再度領悟疼痛
Dialogue: 1,0:07:01.73,0:07:03.51,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}即便如此你依然會堅強起身
Dialogue: 1,0:07:03.51,0:07:04.83,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}絕不能嘲笑這樣的你
Dialogue: 1,0:07:04.83,0:07:07.70,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}就算處處碰壁 仍然要尋找出路
Dialogue: 1,0:07:07.70,0:07:10.93,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}為了讓聲音共鳴迴盪 為了站在此處
Dialogue: 1,0:07:10.93,0:07:12.23,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}我們無數次碰撞
Dialogue: 1,0:07:11.95,0:07:14.40,IN_CH_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}無數次
Dialogue: 1,0:07:12.23,0:07:15.08,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}在心中點亮了一絲火星
Dialogue: 1,0:07:15.08,0:07:17.58,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}請不要撲滅這微小的火苗
Dialogue: 1,0:07:17.58,0:07:20.69,IN_CH_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}不會熄滅
Dialogue: 1,0:07:17.91,0:07:20.02,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}雖然我們還沒有意義與目標
Dialogue: 1,0:07:20.02,0:07:22.88,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}與完美還相去甚遠
Dialogue: 1,0:07:22.88,0:07:25.47,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}但唯獨這音色 才能點燃{\3c&HAA7777&}希{\3c&H2051ED&}望之火
Dialogue: 1,0:07:25.47,0:07:27.18,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}讓思緒轟轟烈烈
Dialogue: 1,0:07:27.93,0:07:30.26,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}深藏內心之中的歌
Dialogue: 1,0:07:29.62,0:07:34.37,IN_CH_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}內心之中
Dialogue: 1,0:07:30.26,0:07:33.21,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}化作一縷{\3c&HDDBB77&}燈{\3c&H2051ED&}火
Dialogue: 1,0:07:33.21,0:07:37.12,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}我們只想奏響這樂音
Dialogue: 1,0:07:37.12,0:07:40.22,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}明天雖然還很遙遠
Dialogue: 1,0:07:40.22,0:07:45.14,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}只管照亮站在此處的我們吧
Dialogue: 1,0:07:45.14,0:07:50.90,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(0,360)}不用因迷路而感到迷茫
Dialogue: 1,0:07:52.13,0:07:55.62,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(360,360)}這就是我們的歌
Dialogue: 1,0:08:08.64,0:08:10.62,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}就算把想法化作話語
Dialogue: 1,0:08:10.85,0:08:12.68,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}迷茫的眼睛依然讓我害怕
Dialogue: 1,0:08:12.68,0:08:14.25,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}即便如此還有音樂
Dialogue: 1,0:08:14.25,0:08:15.85,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}會接納我的心聲
Dialogue: 1,0:08:15.85,0:08:18.31,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}飄零而下的淚水 在這裡也顯得溫暖
Dialogue: 1,0:08:18.31,0:08:20.46,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\3c&H77DD77&}貓{\3c&H2051ED&}窩一般的Live House中
Dialogue: 1,0:08:20.46,0:08:21.56,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}每次擊響樂音
Dialogue: 1,0:08:21.56,0:08:22.88,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}都會火熱綻放
Dialogue: 1,0:08:22.61,0:08:25.03,IN_CH_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}不會熄滅
Dialogue: 1,0:08:22.88,0:08:25.90,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}彼此分享火種 產生共鳴
Dialogue: 1,0:08:25.90,0:08:28.45,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}以暗燃之火 照亮你
Dialogue: 1,0:08:28.45,0:08:31.28,IN_CH_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}高舉起來
Dialogue: 1,0:08:28.73,0:08:30.48,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}我們每個人的拳中
Dialogue: 1,0:08:30.77,0:08:33.04,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}就算握著的東西不同也沒關係
Dialogue: 1,0:08:33.54,0:08:38.19,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}只管在這朋克樂中燃燒相同的熱火
Dialogue: 1,0:08:38.55,0:08:41.02,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}讓這喉嚨奮力發聲
Dialogue: 1,0:08:40.42,0:08:45.07,IN_CH_EP13_TANEBI_CHORUS,,0,0,0,,{\blur3\fad(240,240)}奮力發聲
Dialogue: 1,0:08:41.02,0:08:43.96,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}那一天音符環繞周身
Dialogue: 1,0:08:43.96,0:08:47.83,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}激動的心中藏著藍色火焰
Dialogue: 1,0:08:47.83,0:08:51.01,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\3c&H2051ED&}素非柔{\3c&H88DDFF&}爽{\3c&H2051ED&}的勁風吹拂
Dialogue: 1,0:08:51.01,0:08:55.74,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3}在這小房子中 我們也能乘風自由飛翔
Dialogue: 1,0:08:55.74,0:09:01.65,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(0,360)}我願陪伴你去往任何地方
Dialogue: 1,0:09:07.86,0:09:11.92,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(360,360)}這就是我們的歌
Dialogue: 1,0:09:22.06,0:09:32.11,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(240,240)}我們的樂音迸放 散發著相同的熱量
Dialogue: 1,0:09:32.11,0:09:42.01,IN_CH_EP13_TANEBI_MAIN,,0,0,0,,{\blur3\fad(240,240)}熱{\3c&H9988FF&}愛{\3c&H2051ED&}的歌會伴我們同行 儘管未來充滿未知
Dialogue: 1,0:09:42.01,0:09:46.22,IN_CH_EP13_TANEBI_MAIN,,0,0,110,,{\blur3}我們雖迷失於黑暗 但身邊有人陪伴
Dialogue: 1,0:09:46.45,0:09:50.63,IN_CH_EP13_TANEBI_MAIN,,0,0,110,,{\blur3}當獨自一人時 也要點亮這首歌前行
Dialogue: 1,0:09:51.26,0:09:54.17,IN_CH_EP13_TANEBI_MAIN,,0,0,110,,{\blur3}今後的路途中 還會再度受傷
Dialogue: 1,0:09:54.71,0:09:57.14,IN_CH_EP13_TANEBI_MAIN,,0,0,110,,{\blur3}即便如此 我也不想放開這隻手
Dialogue: 1,0:09:57.41,0:09:59.37,IN_CH_EP13_TANEBI_MAIN,,0,0,110,,{\blur3}彼此走散我也不會放棄
Dialogue: 1,0:09:59.37,0:10:01.81,IN_CH_EP13_TANEBI_MAIN,,0,0,110,,{\blur3}當我摔倒就像你那樣站起身
Dialogue: 1,0:10:02.22,0:10:05.22,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}沒關係 我們一起前行吧
Dialogue: 1,0:10:06.21,0:10:09.94,IN_CH_EP13_TANEBI_INTRO,,0,0,0,,{\blur3}走上這迷路之旅 不再迷茫
Dialogue: 0,0:10:37.87,0:10:46.08,IN_JP_EP13_M2,,0,0,0,,赤の象 獅子 熊 go-go insane
Dialogue: 0,0:10:46.08,0:10:53.88,IN_JP_EP13_M2,,0,0,0,,クラッカー 首謀者 welcome to the house of pain
Dialogue: 0,0:10:53.88,0:11:01.87,IN_JP_EP13_M2,,0,0,0,,夜はサーカス　ヴェールの道化　傍観してないで
Dialogue: 0,0:11:02.48,0:11:10.33,IN_JP_EP13_M2,,0,0,0,,make it hot　アクロバティック・キスで運命の啓示に火を点けて
Dialogue: 0,0:11:11.57,0:11:15.74,IN_JP_EP13_M2,,0,0,0,,無い 成さない style 災い じゃ従わない
Dialogue: 0,0:11:15.74,0:11:19.95,IN_JP_EP13_M2,,0,0,0,,哀 嘲笑い yea’p, till i die
Dialogue: 0,0:11:19.95,0:11:22.20,IN_JP_EP13_M2,,0,0,0,,buddy, alright?
Dialogue: 0,0:11:22.20,0:11:26.37,IN_JP_EP13_M2,,0,0,0,,yes ya gonna jump　yes ya gonna jump　突き抜けてく
Dialogue: 0,0:11:26.37,0:11:30.55,IN_JP_EP13_M2,,0,0,0,,let me be the one　let me be the one　‘YES’ 八芒星へ
Dialogue: 0,0:11:30.55,0:11:34.31,IN_JP_EP13_M2,,0,0,0,,yes ya gonna jump　yes ya gonna jump　笑い 叫ぶ
Dialogue: 0,0:11:34.31,0:11:39.41,IN_JP_EP13_M2,,0,0,0,,本当の人生(life)なんざ忘れて
Dialogue: 0,0:11:39.41,0:11:47.48,IN_JP_EP13_M2,,0,0,0,,赤の象 獅子 熊 go-go insane
Dialogue: 0,0:11:47.48,0:11:55.49,IN_JP_EP13_M2,,0,0,0,,クラッカー 首謀者 welcome to the house of pain
Dialogue: 1,0:10:37.87,0:10:46.08,IN_CH_EP13_M2,,0,0,0,,紅色大象 獅子 熊 go-go insane
Dialogue: 1,0:10:46.08,0:10:53.88,IN_CH_EP13_M2,,0,0,0,,彩帶爆竹 主謀 welcome to the house of pain
Dialogue: 1,0:10:53.88,0:11:01.87,IN_CH_EP13_M2,,0,0,0,,夜晚於馬戲團 面紗小丑 請不要旁觀
Dialogue: 1,0:11:02.48,0:11:10.33,IN_CH_EP13_M2,,0,0,0,,make it hot 雜技接吻點燃命運的啟示
Dialogue: 1,0:11:11.57,0:11:15.74,IN_CH_EP13_M2,,0,0,0,,沒有 不做 style 災難 那就不服從
Dialogue: 1,0:11:15.74,0:11:19.95,IN_CH_EP13_M2,,0,0,0,,哀 嘲笑 yea’p, till i die
Dialogue: 1,0:11:19.95,0:11:22.20,IN_CH_EP13_M2,,0,0,0,,buddy, alright?
Dialogue: 1,0:11:22.20,0:11:26.37,IN_CH_EP13_M2,,0,0,0,,yes ya gonna jump　yes ya gonna jump　不斷突破阻礙
Dialogue: 1,0:11:26.37,0:11:30.55,IN_CH_EP13_M2,,0,0,0,,let me be the one　let me be the one　‘YES’ 向著八芒星
Dialogue: 1,0:11:30.55,0:11:34.31,IN_CH_EP13_M2,,0,0,0,,yes ya gonna jump　yes ya gonna jump　歡笑 叫喊
Dialogue: 1,0:11:34.31,0:11:39.41,IN_CH_EP13_M2,,0,0,0,,將真正的人生拋之腦後
Dialogue: 1,0:11:39.41,0:11:47.48,IN_CH_EP13_M2,,0,0,0,,紅色大象 獅子 熊 go-go insane
Dialogue: 1,0:11:47.48,0:11:55.49,IN_CH_EP13_M2,,0,0,0,,彩帶爆竹 主謀 welcome to the house of pain
Dialogue: 0,0:12:28.44,0:12:32.37,IN_JP_EP13_M3,,0,0,0,,事を/事を拗らせてるの/せてるの
Dialogue: 0,0:12:32.37,0:12:35.94,IN_JP_EP13_M3,,0,0,0,,アルレッキーノ　コルセットを調整してよ
Dialogue: 0,0:12:35.94,0:12:39.84,IN_JP_EP13_M3,,0,0,0,,ちょいと顎上げたりして　鏡の私
Dialogue: 0,0:12:39.84,0:12:42.62,IN_JP_EP13_M3,,0,0,0,,同じに見える違う顔
Dialogue: 0,0:12:42.62,0:12:46.79,IN_JP_EP13_M3,,0,0,0,,化粧映え 誰 double 化け charmin’ チェーミン チューミン
Dialogue: 0,0:12:46.79,0:12:49.87,IN_JP_EP13_M3,,0,0,0,,ハート見せないわ　ほんとんとこ
Dialogue: 0,0:12:49.87,0:12:53.22,IN_JP_EP13_M3,,0,0,0,,平気/平気で そう 涙も流してみせましょ
Dialogue: 0,0:12:53.22,0:12:56.24,IN_JP_EP13_M3,,0,0,0,,正気かしら？ 正気よ
Dialogue: 0,0:12:56.80,0:13:01.77,IN_JP_EP13_M3,,0,0,0,,偽る日々滑らかに
Dialogue: 0,0:13:01.77,0:13:03.81,IN_JP_EP13_M3,,0,0,0,,滑らかに
Dialogue: 0,0:13:03.81,0:13:09.44,IN_JP_EP13_M3,,0,0,0,,無関心でいるために
Dialogue: 0,0:13:14.39,0:13:17.28,IN_JP_EP13_M3,,0,0,0,,うしろ姿　なじるあなた
Dialogue: 0,0:13:21.74,0:13:22.53,IN_JP_EP13_M3,,0,0,0,,[あらら]
Dialogue: 0,0:13:22.53,0:13:26.51,IN_JP_EP13_M3,,0,0,0,,バカね さよなら loser, loser, loser
Dialogue: 0,0:13:27.33,0:13:31.50,IN_JP_EP13_M3,,0,0,0,,私 make up, make up, make up, babe
Dialogue: 0,0:13:31.50,0:13:34.46,IN_JP_EP13_M3,,0,0,0,,あなたを跨ぐ
Dialogue: 0,0:13:51.69,0:13:56.20,IN_JP_EP13_M3,,0,0,0,,うそ/うそ七色うそ笑顔ならポンピンビート
Dialogue: 0,0:13:56.20,0:13:58.10,IN_JP_EP13_M3,,0,0,0,,くすぐるこのこころ
Dialogue: 0,0:13:58.45,0:14:01.78,IN_JP_EP13_M3,,0,0,0,,やり過ごすためのアルゴリズム　冷淡に
Dialogue: 0,0:14:01.78,0:14:06.53,IN_JP_EP13_M3,,0,0,0,,でも何か足りない　わからない/ないけれど
Dialogue: 0,0:14:06.53,0:14:10.17,IN_JP_EP13_M3,,0,0,0,,ah, もはや慣れたわ
Dialogue: 0,0:14:16.21,0:14:18.96,IN_JP_EP13_M3,,0,0,0,,うしろ姿　なじるあなた
Dialogue: 0,0:14:23.30,0:14:24.18,IN_JP_EP13_M3,,0,0,0,,[あらら]
Dialogue: 0,0:14:24.18,0:14:32.08,IN_JP_EP13_M3,,0,0,0,,バカね さよなら loser, loser, loser
Dialogue: 0,0:14:35.30,0:14:38.57,IN_JP_EP13_M3,,0,600,0,,え？ え？ え？ え？
